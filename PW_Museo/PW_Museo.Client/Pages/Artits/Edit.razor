@page "/artists/edit/{id:guid}"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation
@using Models

<PageTitle>Edit Artist</PageTitle>

<h1>Edit Artist</h1>

<hr />
@if (artist == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="artist" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <InputText id="name" class="form-control" @bind-Value="artist.Name" />
                </div>
                <div class="mb-3">
                    <label for="surname" class="form-label">Surname</label>
                    <InputText id="surname" class="form-control" @bind-Value="artist.Surname" />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <InputText id="email" class="form-control" @bind-Value="artist.EmailAddress" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/artists">Back to List</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Artist? artist;

    protected override async Task OnInitializedAsync()
    {
        artist = await Http.GetFromJsonAsync<Artist>($"api/artists/{Id}");
    }

    private async Task HandleValidSubmit()
    {
        await Http.PutAsJsonAsync($"api/artists/{Id}", artist);
        Navigation.NavigateTo("/artists");
    }
}