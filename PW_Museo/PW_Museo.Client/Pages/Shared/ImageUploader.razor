@inject HttpClient Http
@using Models

<div class="mb-3">
    <label class="form-label">@Label</label>
    @if (!string.IsNullOrEmpty(PreviewUrl))
    {
        <div class="mb-2">
            <img src="@PreviewUrl" alt="preview" style="max-height:200px; max-width:100%; object-fit:contain;" />
        </div>
    }
    <InputFile OnChange="HandleFileSelected" accept="image/*" class="form-control" />
    @if (uploading)
    {
        <small class="text-muted">Uploading...</small>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "Image";
    [Parameter] public EventCallback<Guid> OnImageUploaded { get; set; }
    [Parameter] public string? PreviewUrl { get; set; }

    private bool uploading = false;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploading = true;
        var file = e.File;
        using var content = new MultipartFormDataContent();
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        content.Add(new StreamContent(stream), "file", file.Name);
        var response = await Http.PostAsync("api/images/upload", content);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            if (result is not null)
                await OnImageUploaded.InvokeAsync(result.Id);
        }
        uploading = false;
    }

    private record UploadResult(Guid Id, string Url);
}