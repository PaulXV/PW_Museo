@page "/shows/edit/{id:guid}"
@inject IShowService showSRV
@using PW_Museo.Client.Services.Shows;
@inject NavigationManager NavigationManager
@using Models

<PageTitle>Edit Show</PageTitle>

<h1>Edit Show</h1>

<hr />
@if (show == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="show" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <InputText id="title" class="form-control" @bind-Value="show.Title" />
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <InputText id="description" class="form-control" @bind-Value="show.Description" />
                </div>
                <div class="mb-3">
                    <label for="startdate" class="form-label">Start Date</label>
                    <InputDate id="startdate" class="form-control" @bind-Value="show.StartDate" />
                </div>
                <div class="mb-3">
                    <label for="enddate" class="form-label">End Date</label>
                    <InputDate id="enddate" class="form-control" @bind-Value="show.EndDate" />
                </div>
                <div class="mb-3">
                    <label for="status" class="form-label">Status</label>
                    <InputText id="status" class="form-control" @bind-Value="show.Status" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/shows">Back to List</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Show? show;

    protected override async Task OnInitializedAsync()
    {
        show = await showSRV.GetShowById(Id);
    }

    private async Task HandleValidSubmit()
    {
        await showSRV.UpdateShow(show!);
        NavigationManager.NavigateTo("/shows");
    }
}
