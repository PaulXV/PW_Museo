@page "/shows/create"
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using Models

<PageTitle>Create Show</PageTitle>

<h1>Create Show</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Model="show" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <InputText id="title" class="form-control" @bind-Value="show.Title" />
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <InputText id="description" class="form-control" @bind-Value="show.Description" />
            </div>
            <div class="mb-3">
                <label for="startdate" class="form-label">Start Date</label>
                <InputDate id="startdate" class="form-control" @bind-Value="show.StartDate" />
            </div>
            <div class="mb-3">
                <label for="enddate" class="form-label">End Date</label>
                <InputDate id="enddate" class="form-control" @bind-Value="show.EndDate" />
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Status</label>
                <InputText id="status" class="form-control" @bind-Value="show.Status" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/shows">Back to List</a>
</div>

@code {
    private Show show = new Show { 
        Id = Guid.NewGuid(), 
        Title = "", 
        Description = "", 
        StartDate = DateTime.Now, 
        EndDate = DateTime.Now.AddMonths(1), 
        Status = "Active",
        ImageId = Guid.Empty,
        AuthorId = Guid.Empty
    };

    private async Task HandleValidSubmit()
    {
        await Http.PostAsJsonAsync("api/shows", show);
        NavigationManager.NavigateTo("/shows");
    }
}
