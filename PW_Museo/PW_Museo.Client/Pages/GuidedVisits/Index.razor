@page "/guidedvisits"
@inject HttpClient Http
@using Models

<PageTitle>Guided Visits</PageTitle>

<h1>Guided Visits</h1>

<p>
    <a href="/guidedvisits/create">Create New</a>
</p>

@if (guidedVisits == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var visit in guidedVisits)
            {
                <tr>
                    <td>@visit.Date.ToShortDateString()</td>
                    <td>@visit.Status</td>
                    <td>
                        <a href="/guidedvisits/edit/@visit.Id">Edit</a> |
                        <button class="btn btn-link link-danger p-0 align-baseline" @onclick="() => DeleteVisit(visit.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Guided_Visit[]? guidedVisits;

    protected override async Task OnInitializedAsync()
    {
        guidedVisits = await Http.GetFromJsonAsync<Guided_Visit[]>("api/guidedvisits");
    }

    private async Task DeleteVisit(Guid id)
    {
        await Http.DeleteAsync($"api/guidedvisits/{id}");
        guidedVisits = await Http.GetFromJsonAsync<Guided_Visit[]>("api/guidedvisits");
    }
}