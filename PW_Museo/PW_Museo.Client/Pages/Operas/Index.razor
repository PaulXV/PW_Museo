@page "/operas"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@using Models

<PageTitle>Operas</PageTitle>

<h1>Operas</h1>

<p>
    <a href="/operas/create">Create New</a>
</p>

@if (operas == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Technic</th>
                <th>Typology</th>
                <th>Creation Year</th>
                <th>Author</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var opera in operas)
            {
                <tr>
                    <td>@opera.Title</td>
                    <td>@opera.Description</td>
                    <td>@opera.Techinic</td>
                    <td>@opera.Typology</td>
                    <td>@opera.creationYear.ToShortDateString()</td>
                    <td>@GetAuthorName(opera.AuthorId)</td>
                    <td>
                        <a href="/operas/edit/@opera.Id">Edit</a> |
                        <button class="btn btn-link link-danger p-0 align-baseline" @onclick="() => DeleteOpera(opera.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Opera[]? operas;
    private Artist[]? artists;

    protected override async Task OnInitializedAsync()
    {
        operas = await Http.GetFromJsonAsync<Opera[]>("api/operas");
        artists = await Http.GetFromJsonAsync<Artist[]>("api/artists");
    }

    private string GetAuthorName(Guid authorId)
    {
        var artist = artists?.FirstOrDefault(a => a.Id == authorId);
        return artist is not null ? $"{artist.Name} {artist.Surname}" : "—";
    }

    private async Task DeleteOpera(Guid id)
    {
        await Http.DeleteAsync($"api/operas/{id}");
        operas = await Http.GetFromJsonAsync<Opera[]>("api/operas");
    }
}