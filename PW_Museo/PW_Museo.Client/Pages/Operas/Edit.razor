@page "/operas/edit/{id:guid}"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject IOperaService operaSRV
@using PW_Museo.Client.Services.Operas;
@inject IShowService showSRV
@using PW_Museo.Client.Services.Shows;
@inject IArtistService artistSRV
@using PW_Museo.Client.Services.Artists;
@inject HttpClient Http
@inject NavigationManager Navigation
@using Models

<PageTitle>Edit Opera</PageTitle>

<h1>Edit Opera</h1>

<hr />
@if (opera == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="opera" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <InputText id="title" class="form-control" @bind-Value="opera.Title" />
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <InputText id="description" class="form-control" @bind-Value="opera.Description" />
                </div>
                <div class="mb-3">
                    <label for="technic" class="form-label">Technic</label>
                    <InputText id="technic" class="form-control" @bind-Value="opera.Techinic" />
                </div>
                <div class="mb-3">
                    <label for="typology" class="form-label">Typology</label>
                    <InputText id="typology" class="form-control" @bind-Value="opera.Typology" />
                </div>
                <div class="mb-3">
                    <label for="creationYear" class="form-label">Creation Year</label>
                    <InputDate id="creationYear" class="form-control" @bind-Value="opera.creationYear" />
                </div>
                <div class="mb-3">
                    <label for="author" class="form-label">Author</label>
                    <InputSelect id="author" class="form-control" @bind-Value="opera.AuthorId">
                        <option value="@Guid.Empty">— Select Author —</option>
                        @foreach (var artist in artists)
                        {
                            <option value="@artist.Id">@artist.Name @artist.Surname</option>
                        }
                    </InputSelect>
                </div>
                <div class="mb-3">
                    <label for="show" class="form-label">Show (optional)</label>
                    <InputSelect id="show" class="form-control" @bind-Value="opera.ShowId">
                        <option value="@Guid.Empty">— No Show —</option>
                        @foreach (var show in shows)
                        {
                            <option value="@show.Id">@show.Title</option>
                        }
                    </InputSelect>
                </div>
                <div class="mb-3">
                    <label class="form-label">Image</label>
                    @if (!string.IsNullOrEmpty(previewUrl))
                    {
                        <div class="mb-2">
                            <img src="@previewUrl" alt="preview" style="max-height:200px; max-width:100%; object-fit:contain;" />
                        </div>
                    }
                    <InputFile OnChange="HandleImageUpload" accept="image/*" class="form-control" />
                    @if (uploading)
                    {
                        <small class="text-muted">Uploading...</small>
                    }
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/operas">Back to List</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Opera? opera;
    private Artist[] artists = [];
    private Show[] shows = [];
    private string? previewUrl;
    private bool uploading = false;

    protected override async Task OnInitializedAsync()
    {
        opera = await operaSRV.GetOperaById(Id);
        artists = await artistSRV.GetAllArtists() ?? [];
        shows = await showSRV.GetAllShows() ?? [];
        previewUrl = opera?.ImageSrc;
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        uploading = true;
        var file = e.File;
        using var content = new MultipartFormDataContent();
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        content.Add(new StreamContent(stream), "file", file.Name);
        var response = await Http.PostAsync("api/images/upload", content);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            if (result is not null)
            {
                opera!.ImageId = result.Id;
                previewUrl = result.Url;
            }
        }
        uploading = false;
    }

    private async Task HandleValidSubmit()
    {
        await operaSRV.UpdateOpera(opera!);
        Navigation.NavigateTo("/operas");
    }

    private record UploadResult(Guid Id, string Url);
}